server {
    # Error 1: listen expects a numeric port string
    listen eighty_eighty;
    
    # Error 2: client_max_body_size expects numeric sizes (e.g., "10M" or numbers)
    client_max_body_size unlimited;

    location / {
        root /var/www;
        # Error 3: Invalid HTTP status code mapping types
        return bad_gateway http://example.com;
    }
}